# Dependency directories
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Databases
backend/data/*
!backend/data/.gitkeep
*.db
*.sqlite

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Production build outputs
dist/
build/
frontend/dist/

# IDE / System files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docker local overrides
docker-compose.override.yml

# SSL Certificates (leave the directory but ignore files)
certs/*
!certs/.gitkeep
